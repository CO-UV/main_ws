<?xml version="1.0"?>
<!--
  4-wheel skid-steer UGV for warehouse path following.

  A rear-wheel-drive rover with frictionless casters fishtails under a straight
  command, so this model uses a directionally-stable 4-wheel skid-steer layout:
  two left wheels and two right wheels driven by a single gz DiffDrive system.
  Driven by geometry_msgs/Twist on /ugv/cmd_vel; publishes odometry (relative to
  spawn) on /ugv/odom. Body mesh reuses PX4's rover_differential base for looks.
-->
<sdf version="1.9">
  <model name='ugv_diff'>
    <link name='base_link'>
      <pose relative_to='__model__'>0 0 0.1 0 0 0</pose>
      <inertial>
        <mass>6.0</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia>
          <ixx>0.12</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.20</iyy><iyz>0</iyz><izz>0.28</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <pose>0 0 -0.05 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://rover_differential/meshes/rover_differential_base.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name='collision'>
        <geometry>
          <box><size>0.9 0.5 0.1</size></box>
        </geometry>
      </collision>
    </link>

    <!-- Four wheels: FL, FR, RL, RR. Left pair and right pair driven together. -->
    <!-- front_left -->
    <link name='wheel_fl_link'>
      <pose relative_to="base_link">0.25 0.3 0 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass>
        <inertia><ixx>0.000807</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000807</iyy><iyz>0</iyz><izz>0.0014</izz></inertia>
      </inertial>
      <visual name='visual'><geometry><mesh><uri>model://rover_differential/meshes/rover_differential_wheel.dae</uri></mesh></geometry></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.1</radius><length>0.1</length></cylinder></geometry>
        <surface><friction><ode><mu>1.2</mu><mu2>0.6</mu2><fdir1>1 0 0</fdir1></ode></friction></surface>
      </collision>
    </link>
    <!-- front_right -->
    <link name='wheel_fr_link'>
      <pose relative_to="base_link">0.25 -0.3 0 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass>
        <inertia><ixx>0.000807</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000807</iyy><iyz>0</iyz><izz>0.0014</izz></inertia>
      </inertial>
      <visual name='visual'><geometry><mesh><uri>model://rover_differential/meshes/rover_differential_wheel.dae</uri></mesh></geometry></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.1</radius><length>0.1</length></cylinder></geometry>
        <surface><friction><ode><mu>1.2</mu><mu2>0.6</mu2><fdir1>1 0 0</fdir1></ode></friction></surface>
      </collision>
    </link>
    <!-- rear_left -->
    <link name='wheel_rl_link'>
      <pose relative_to="base_link">-0.25 0.3 0 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass>
        <inertia><ixx>0.000807</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000807</iyy><iyz>0</iyz><izz>0.0014</izz></inertia>
      </inertial>
      <visual name='visual'><geometry><mesh><uri>model://rover_differential/meshes/rover_differential_wheel.dae</uri></mesh></geometry></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.1</radius><length>0.1</length></cylinder></geometry>
        <surface><friction><ode><mu>1.2</mu><mu2>0.6</mu2><fdir1>1 0 0</fdir1></ode></friction></surface>
      </collision>
    </link>
    <!-- rear_right -->
    <link name='wheel_rr_link'>
      <pose relative_to="base_link">-0.25 -0.3 0 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass>
        <inertia><ixx>0.000807</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000807</iyy><iyz>0</iyz><izz>0.0014</izz></inertia>
      </inertial>
      <visual name='visual'><geometry><mesh><uri>model://rover_differential/meshes/rover_differential_wheel.dae</uri></mesh></geometry></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.1</radius><length>0.1</length></cylinder></geometry>
        <surface><friction><ode><mu>1.2</mu><mu2>0.6</mu2><fdir1>1 0 0</fdir1></ode></friction></surface>
      </collision>
    </link>

    <joint name='wheel_fl_joint' type='revolute'>
      <pose relative_to='wheel_fl_link'/>
      <parent>base_link</parent><child>wheel_fl_link</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name='wheel_fr_joint' type='revolute'>
      <pose relative_to='wheel_fr_link'/>
      <parent>base_link</parent><child>wheel_fr_link</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name='wheel_rl_joint' type='revolute'>
      <pose relative_to='wheel_rl_link'/>
      <parent>base_link</parent><child>wheel_rl_link</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name='wheel_rr_joint' type='revolute'>
      <pose relative_to='wheel_rr_link'/>
      <parent>base_link</parent><child>wheel_rr_link</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <!-- Skid-steer diff drive: both left wheels vs both right wheels.
         Wheel-encoder odometry is inaccurate for skid-steer (lateral slip), so
         its odom is parked on an unused topic and the controller instead uses
         the ground-truth OdometryPublisher below. -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_fl_joint</left_joint>
      <left_joint>wheel_rl_joint</left_joint>
      <right_joint>wheel_fr_joint</right_joint>
      <right_joint>wheel_rr_joint</right_joint>
      <wheel_separation>0.6</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <max_linear_acceleration>1.5</max_linear_acceleration>
      <topic>/ugv/cmd_vel</topic>
      <odom_topic>/ugv/wheel_odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- Ground-truth planar odometry (accurate under skid), relative to spawn. -->
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_topic>/ugv/odom</odom_topic>
      <dimensions>2</dimensions>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </model>
</sdf>
